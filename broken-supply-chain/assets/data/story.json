        "definition": "something happens later than planned",
        "translation": "задержка"
      },
      {
        "term": "warehouse",
        "definition": "a large place where goods are stored",
        "translation": "склад"
      },
      {
        "term": "route",
        "definition": "the road or path for a delivery",
        "translation": "маршрут"
      },
      {
        "term": "tracking number",
        "definition": "a code used to follow a shipment",
        "translation": "номер отслеживания"
      }
    ],
