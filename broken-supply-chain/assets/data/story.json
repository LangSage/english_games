{
  "meta": {
    "title": "The Broken Supply Chain",
    "description": "A phone-first English logistics game about a delayed shipment, missing cargo, and an urgent customer.",
    "caseTitle": "The Broken Supply Chain",
    "caseTag": "Case 01",
    "playerName": "Emir",
    "defaultDifficulty": "easy",
    "defaultAudioRate": 0.9,
    "startNotes": [
      "A shipment from Germany is late.",
      "Find the delay, the missing cargo, and a fast solution."
    ],
    "endTitle": "The urgent delivery is moving.",
    "endSummary": "You split the shipment and sent the urgent spare parts first.",
    "preGameVocab": [
      {
        "term": "shipment",
        "definition": "goods sent from one place to another",
        "translation": "поставка"
      },
      {
        "term": "cargo",
        "definition": "the goods inside a truck or ship",
        "translation": "груз"
      },
      {
